  "formulas": {
    "lambda_cost": {
      "formula": "(invocations * $0.20 / 1M) + ((memory_gb * duration_s * invocations) * $0.0000166667)",
      "variables": {
        "invocations": "Number of Lambda invocations per month",
        "memory_gb": "Lambda memory in GB (0.5 for 512MB)",
        "duration_s": "Average duration in seconds per invocation"
      }
    },
    "bedrock_cost_haiku": {
      "formula": "(input_tokens * $0.00000025) + (output_tokens * $0.00000125)",
      "per_request_estimate": {
        "avg_input_tokens": 1500,
        "avg_output_tokens": 500,
        "cost_per_request": 0.001
      }
    },
    "bedrock_cost_sonnet": {
      "formula": "(input_tokens * $0.000003) + (output_tokens * $0.000015)",
      "per_request_estimate": {
        "avg_input_tokens": 1500,
        "avg_output_tokens": 500,
        "cost_per_request": 0.012
      }
    },
    "monthly_cost_total": {
      "formula": "fixed_costs + (monthly_requests * llm_call_rate * cost_per_llm_request) + lambda_cost + cloudwatch_cost",
      "note": "llm_call_rate = 0.70 (30% of requests are static, no LLM)"
    }
  },
  "assumptions": {
    "lambda": {
