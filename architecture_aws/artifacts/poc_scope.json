  "success_criteria": {
    "functional": [
      {
        "id": "SC-F01",
        "criterion": "All 12 scenarios execute successfully",
        "metric": "scenarios_passed / 12",
        "threshold": "12/12 (100%)"
      },
      {
        "id": "SC-F02",
        "criterion": "Intent classification accuracy",
        "metric": "correct_classifications / total_test_cases",
        "threshold": "> 95%"
      },
      {
        "id": "SC-F03",
        "criterion": "RAG returns relevant information",
        "metric": "chunks with score > 0.7 / total RAG queries",
        "threshold": "> 80%"
      },
      {
        "id": "SC-F04",
        "criterion": "API returns correct data",
        "metric": "correct_responses / total_api_queries",
