%% AWS Container Diagram - MARH Consultive Agent
%% Data: 2026-07-23 (revisão corretiva)
%% Region: sa-east-1
%% Modelo: PROPOSED_PENDING_ACCOUNT_VALIDATION
%% RAG: Lambda → embedding → S3 Vectors direto (KB gerenciada não confirmada)

graph TB
    subgraph External["Sistemas Externos"]
        APIMARH["API MARH<br/>(Invocador — IAM)"]
        MaHrOrch["ma-hr-orch<br/>(Dados + Autorização)<br/>HTTP GET only"]
    end

    subgraph AWS_SA_EAST_1["AWS sa-east-1 (São Paulo)"]
        subgraph Compute["Computação"]
            Lambda["AWS Lambda<br/>Python 3.12 / 512MB<br/>Timeout: 30s"]
        end

        subgraph AI_ML["AI/ML — PROPOSED_PENDING_ACCOUNT_VALIDATION"]
            BedrockRuntime["Bedrock Runtime<br/>(modelo confirmado ACTIVE)<br/>RAG_ONLY: embedding + geração"]
        end

        subgraph Storage["Armazenamento"]
            S3Docs["S3 Bucket<br/>(marh_feature_knowledge.md)<br/>KMS + Versioning + Metadados"]
            S3Vectors["S3 Vectors<br/>(embeddings RAG)<br/>REQUIRES_ACCOUNT_VALIDATION"]
        end

        subgraph Security["Segurança"]
            SecretsManager["Secrets Manager<br/>(token ma-hr-orch)"]
            KMS["KMS<br/>(CMK — S3 + Secrets)"]
        end

        subgraph Observability["Observabilidade"]
            CloudWatch["CloudWatch<br/>(Logs JSON + Metrics)<br/>Sem PII — 30 dias"]
            XRay["X-Ray<br/>(Distributed Tracing)"]
        end
    end

    %% Connections
    APIMARH -->|"InvokeFunction (SDK)<br/>ou Function URL AWS_IAM"| Lambda
    Lambda -->|"InvokeModel<br/>(embedding + geração<br/>RAG_ONLY apenas)"| BedrockRuntime
    Lambda -->|"QueryVectors<br/>(retrieval direto)"| S3Vectors
    Lambda -->|"GetObject<br/>(chunks aprovados)"| S3Docs
    Lambda -->|"HTTP GET HTTPS<br/>(timeout: 3s+8s)"| MaHrOrch
    Lambda -->|"GetSecretValue"| SecretsManager
    Lambda -->|"PutLogEvents<br/>(sem PII)"| CloudWatch
    Lambda -->|"PutTraceSegments"| XRay
    SecretsManager -->|"Decrypt"| KMS
    S3Docs -->|"KMS Encrypt/Decrypt"| KMS

    %% Styling
    classDef external fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef compute fill:#ff9900,stroke:#333,stroke-width:2px,color:#fff
    classDef ai fill:#9c27b0,stroke:#333,stroke-width:2px,color:#fff
    classDef storage fill:#3f51b5,stroke:#333,stroke-width:2px,color:#fff
    classDef security fill:#f44336,stroke:#333,stroke-width:2px,color:#fff
    classDef observability fill:#4caf50,stroke:#333,stroke-width:2px,color:#fff

    class APIMARH,MaHrOrch external
    class Lambda compute
    class BedrockRuntime ai
    class S3Docs,S3Vectors storage
    class SecretsManager,KMS security
    class CloudWatch,XRay observability
