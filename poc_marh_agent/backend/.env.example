# Configuração do backend MARH Agent
# Copie para .env e ajuste se necessário.
# Nunca inclua credenciais reais neste arquivo.

# --- Modo de operação ---
# MOCK_LOCAL = usa clientes mock (dev local / testes)
# INTEGRATED = usa clientes reais (ma-hr-orch + Bedrock)
AGENT_MODE=MOCK_LOCAL

# --- Ambiente ---
# HML = homologação
# PRD = produção
ENVIRONMENT=HML

# --- Logging ---
LOG_LEVEL=INFO

# --- Limites ---
MAX_MESSAGE_LENGTH=2000

# --- ma-hr-orch (necessário quando AGENT_MODE=INTEGRATED) ---
MA_HR_ORCH_BASE_URL=
MA_HR_ORCH_TIMEOUT_SECONDS=10

# --- Amazon Bedrock (necessário quando AGENT_MODE=INTEGRATED) ---
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_KNOWLEDGE_BASE_ID=

# --- CORS (separar múltiplas origens por vírgula) ---
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
