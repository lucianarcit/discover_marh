# Configuração do backend MARH Agent
# Copie para .env e ajuste se necessário.
# Nunca inclua credenciais reais neste arquivo.

# --- Eixo de dados (ma-hr-orch) ---
# MOCK       = usa MockMaHrOrchClient (dev local / testes / Fase 3 isolada)
# INTEGRATED = usa HttpMaHrOrchClient (Fase 2 — ma-hr-orch real)
DATA_SOURCE_MODE=MOCK

# --- Eixo de conhecimento (INT-008 a INT-021) ---
# MOCK        = usa MockKnowledgeClient (dev local / testes)
# BEDROCK_RAG = usa BedrockRagKnowledgeClient (Fase 3)
KNOWLEDGE_MODE=MOCK

# --- Legado (mantido para retrocompatibilidade) ---
# DATA_SOURCE_MODE tem prioridade; AGENT_MODE é fallback
AGENT_MODE=MOCK_LOCAL

# --- Ambiente ---
ENVIRONMENT=HML

# --- Logging ---
LOG_LEVEL=INFO

# --- Limites ---
MAX_MESSAGE_LENGTH=2000

# --- ma-hr-orch (necessário quando DATA_SOURCE_MODE=INTEGRATED) ---
MA_HR_ORCH_BASE_URL=
MA_HR_ORCH_TIMEOUT_SECONDS=10

# --- Amazon Bedrock ---
# Região obrigatória: sa-east-1. Cross-region proibido.
BEDROCK_REGION=sa-east-1

# Modelo de embedding (configuração de infraestrutura — não usado no runtime do Retriever)
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Modelo de geração — obrigatório quando KNOWLEDGE_MODE=BEDROCK_RAG
# Seleção definitiva no Passo 10 (dataset de avaliação)
# Não usar: Claude 3 Haiku, Claude 3.5 Haiku, Claude 3 Sonnet
# Candidatos: mistral.magistral-small-2509, mistral.mistral-large-2402-v1:0
BEDROCK_MODEL_ID=

# Knowledge Base ID — obrigatório quando KNOWLEDGE_MODE=BEDROCK_RAG
BEDROCK_KNOWLEDGE_BASE_ID=

# Threshold de score para aprovação de chunks (PROPOSED_PENDING_EVALUATION)
RETRIEVAL_SCORE_THRESHOLD=0.70

# --- CORS (separar múltiplas origens por vírgula) ---
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
