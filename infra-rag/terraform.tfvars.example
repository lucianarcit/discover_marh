# Exemplo de variáveis para o ambiente RAG HML
# Copie para terraform.tfvars e preencha os valores reais.
# NUNCA versionar terraform.tfvars com valores reais.

aws_region  = "sa-east-1"
environment = "HML"

# Modelo de geração — selecionar após Passo 10 (dataset de avaliação)
# Candidatos validados no probe regional (sa-east-1):
#   mistral.magistral-small-2509
#   mistral.mistral-large-2402-v1:0
#   google.gemma-3-27b-it
#   qwen.qwen3-32b-v1:0
# Excluídos: Haiku, Haiku 3.5, Sonnet v1
bedrock_model_id = "mistral.magistral-small-2509"

# Threshold provisório — calibrar no Passo 10
# Status: USE_0_65_PROVISIONALLY
retrieval_score_threshold = 0.65
retrieval_top_k           = 5

# Lambda
lambda_memory_size = 512
lambda_timeout     = 60

# Logs
log_retention_days = 30

# API Gateway
throttling_burst_limit = 50
throttling_rate_limit  = 100

# CORS
cors_allowed_origins = ["https://meualelo-webviews-hml.siteteste.inf.br"]
