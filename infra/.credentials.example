# Credenciais AWS para deploy local
# Copie este arquivo para .credentials e preencha com seus acessos:
#   copy .credentials.example .credentials
#
# NUNCA commite o arquivo .credentials!

[aws]
aws_access_key_id = YOUR_ACCESS_KEY_ID
aws_secret_access_key = YOUR_SECRET_ACCESS_KEY
region = sa-east-1

[ma_hr_orch]
api_key = YOUR_API_KEY
base_url = https://api.alelo.com.br/ma-hr-orch/v1
