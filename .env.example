# ─── Variáveis de Ambiente - Discover Alelo ──────────────────────────────────
# Ambiente: Homologação / UAT
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA versione o .env no Git.
# ──────────────────────────────────────────────────────────────────────────────

# Autenticação OAuth2
ALELO_AUTH_URL=https://api.homologacaoalelo.com.br/alelo/uat/identity-server-auth/v1/oauth2/token
ALELO_API_BASE_URL=https://api-ma.homologacaoalelo.com.br/alelo/uat

# Credenciais (substituir pelos valores reais)
ALELO_CLIENT_ID=seu_client_id_aqui
ALELO_CLIENT_SECRET=seu_client_secret_aqui
ALELO_BASIC_AUTH=Basic seu_valor_base64_aqui
ALELO_IBM_CLIENT_ID=seu_ibm_client_id_aqui

# Identificadores (substituir pelos valores reais)
ALELO_FNP=seu_fingerprint_aqui
ALELO_USER_ID=seu_user_id_aqui

# Refresh token (obtido da sessão ativa - expira periodicamente)
ALELO_REFRESH_TOKEN=seu_refresh_token_aqui

# Informações da aplicação
ALELO_AUTH_TYPE=IS-ALELO
ALELO_APP_VERSION=8.55.0 (2026072003)
ALELO_PLATFORM=IOS

# Runtime
ALELO_CONNECT_TIMEOUT=10
ALELO_READ_TIMEOUT=60
ALELO_VERIFY_SSL=true
