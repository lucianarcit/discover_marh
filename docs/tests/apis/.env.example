# ─── Variáveis para test_profile_safe.py ─────────────────────────────────────
# NÃO preencha este arquivo com valores reais.
# Copie os nomes e defina como variáveis de ambiente temporárias na sessão.
#
# Uso no Windows (cmd):
#   set ALELO_CLIENT_ID=<valor>
#   set ALELO_CLIENT_SECRET=<valor>
#   ...
#   python docs/tests/test_profile_safe.py
#
# O token será solicitado interativamente (getpass) ou via ALELO_ACCESS_TOKEN.
# ──────────────────────────────────────────────────────────────────────────────
# Alelo API - Homologação
ALELO_BASE_URL=https://api-ma.homologacaoalelo.com.br
ALELO_ACCESS_TOKEN=seu_access_token_aqui
ALELO_CLIENT_ID=seu_client_id_aqui
ALELO_CLIENT_SECRET=seu_client_secret_aqui
ALELO_FNP=seu_fnp_aqui
ALELO_BASIC_AUTH=Basic_seu_valor_base64_aqui
ALELO_USER_ID=seu_user_id_aqui
IBM_CLIENT_ID=seu_ibm_client_id_aqui

# Informações da aplicação
ALELO_APP_VERSION=8.55.0 (2026072003)
ALELO_AUTH_TYPE=IS-ALELO
ALELO_PLATFORM=IOS
ALELO_API_TIMEOUT_SECONDS=15
